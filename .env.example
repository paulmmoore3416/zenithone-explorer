# ZenithOne Explorer - Environment Configuration Template
# Copy this file to .env and update with your values

# Application
APP_NAME=ZenithOne Explorer
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8080
WORKERS=4

# Security
SECRET_KEY=change-this-to-a-random-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600
PASSWORD_MIN_LENGTH=8

# Database
DATABASE_URL=sqlite:///./backend/data/database.db
DATABASE_ECHO=false

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100
RATE_LIMIT_ADMIN=200

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_CREDENTIALS=true

# Podman
PODMAN_SOCKET=unix:///run/user/1000/podman/podman.sock
CONTAINER_MAX_CPU=2
CONTAINER_MAX_MEMORY=1024

# Ollama / Qwen2.5
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:latest
AI_ENABLED=true

# Monitoring
METRICS_INTERVAL=5
METRICS_RETENTION_DAYS=90
LOG_LEVEL=INFO
LOG_FILE=backend/data/logs/application.log

# Subsystems
JES_MAX_JOBS=1000
JES_SPOOL_SIZE=10737418240
CICS_MAX_TRANSACTIONS=10000
CICS_TIMEOUT=30
DB2_MAX_CONNECTIONS=100
DB2_CACHE_SIZE=536870912
TSO_MAX_SESSIONS=50
TSO_TIMEOUT=1800

# Workload Manager
WORKLOAD_MAX_CONCURRENT=100
WORKLOAD_DEFAULT_TIMEOUT=3600
WORKLOAD_QUEUE_SIZE=1000

# UI
UI_HOST=0.0.0.0
UI_PORT=3000
UI_THEME=dark
UI_REFRESH_INTERVAL=5

# Email (Optional)
EMAIL_ENABLED=false
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=noreply@zenitone.local

# Backup
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=./backup

# Development
DEV_MODE=true
RELOAD=true
